{
  "name": "web-app",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "vite --host :: --port 3000",
    "tsc": "tsc --noEmit",
    "build": "tsc && vite build",
    "preview": "vite preview --host :: --port 3000",
    "generate:sitemap": "node scripts/sitemap-generator.js",
    "deploy:zip": "npm run generate:sitemap && npm run build && cd dist && bestzip ../deploy.zip *",

"/><w:left w:type="dxa" w:w="160"/><w:bottom w:type="dxa" w:w="100"/><w:right w:type="dxa" w:w="160"/></w:tcMar></w:tcPr><w:p><w:r><w:rPr><w:rFonts w:ascii="Arial" w:cs="Arial" w:eastAsia="Arial" w:hAnsi="Arial"/><w:color w:val="222222"/><w:sz w:val="22"/><w:szCs w:val="22"/></w:rPr><w:t xml:space="preserve">reducción en consumo energético con sistemas de refrigeración líquida (Nvidia, líderes cloud)</w:t></w:r></w:p></w:tc></w:tr><w:tr><w:tc><w:tcPr><w:tcW w:type="dxa" w:w="3120"/><w:tcBorders><w:top w:val="none"/><w:left w:val="none"/><w:bottom w:val="none"/><w:right w:val="none"/></w:tcBorders><w:shd w:fill="D6EAF8" w:val="clear"/><w:tcMar><w:top w:type="dxa" w:w="100"/><w:left w:type="dxa" w:w="160"/><w:bottom w:type="dxa" w:w="100"/><w:right w:type="dxa" w:w="160"/></w:tcMar></w:tcPr><w:p><w:r><w:rPr><w:rFonts w:ascii="Arial" w:cs="Arial" w:eastAsia="Arial" w:hAnsi="Arial"/><w:b/><w:bCs/><w:color w:val="1A5276"/><w:sz w:val="22"/><w:szCs w:val="22"/></w:rPr><w:t xml:space="preserve">50% clientes B2B</w:t></w:r></w:p></w:tc><w:tc><w:tcPr><w:tcW w:type="dxa" w:w="6240"/><w:tcBorders><w:top w:val="none"/><w:left w:val="none"/><w:bottom w:val="none"/><w:right w:val="none"/></w:tcBorders><w:shd w:fill="D6EAF8" w:val="clear"/><w:tcMar><w:top w:type="dxa" w:w="100"/><w:left w:type="dxa" w:w="160"/><w:bottom w:type="dxa" w:w="100"/><w:right w:type="dxa" w:w="160"/></w:tcMar></w:tcPr><w:p><w:r><w:rPr><w:rFonts w:ascii="Arial" w:cs="Arial" w:eastAsia="Arial" w:hAnsi="Arial"/><w:color w:val="222222"/><w:sz w:val="22"/><w:szCs w:val="22"/></w:rPr><w:t xml:space="preserve">ya priorizan proveedores sostenibles — y crecerá a 2/3 en 3 años</w:t></w:r></w:p></w:tc></w:tr><w:tr><w:tc><w:tcPr><w:tcW w:type="dxa" w:w="3120"/><w:tcBorders><w:top w:val="none"/><w:left w:val="none"/><w:bottom w:val="none"/><w:right w:val="none"/></w:tcBorders><w:shd w:fill="EBF5FB" w:val="clear"/><w:tcMar><w:top w:type="dxa" w:w="100"/><w:left w:type="dxa" w:w="160"/><w:bottom w:type="dxa" w:w="100"/><w:right w:type="dxa" w:w="160"/></w:tcMar></w:tcPr><w:p><w:r><w:rPr><w:rFonts w:ascii="Arial" w:cs="Arial" w:eastAsia="Arial" w:hAnsi="Arial"/><w:b/><w:bCs/><w:color w:val="1A5276"/><w:sz w:val="22"/><w:szCs w:val="22"/></w:rPr><w:t xml:space="preserve">Marzo 2026</w:t></w:r></w:p></w:tc><w:tc><w:tcPr><w:tcW w:type="dxa" w:w="6240"/><w:tcBorders><w:top w:val="none"/><w:left w:val="none"/><w:bottom w:val="none"/><w:right w:val="none"/></w:tcBorders><w:shd w:fill="EBF5FB" w:val="clear"/><w:tcMar><w:top w:type="dxa" w:w="100"/><w:left w:type="dxa" w:w="160"/><w:bottom w:type="dxa" w:w="100"/><w:right w:type="dxa" w:w="160"/></w:tcMar></w:tcPr><w:p><w:r><w:rPr><w:rFonts w:ascii="Arial" w:cs="Arial" w:eastAsia="Arial" w:hAnsi="Arial"/><w:color w:val="222222"/><w:sz w:val="22"/><w:szCs w:val="22"/></w:rPr><w:t xml:space="preserve">entra en vigor la directiva europea anti-greenwashing: información ambiental verificable o multas</w:t></w:r></w:p></w:tc></w:tr></w:tbl><w:p><w:pPr><w:spacing w:after="0" w:before="280"/></w:pPr><w:r><w:t xml:space="preserve"></w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Arial" w:cs="Arial" w:eastAsia="Arial" w:hAnsi="Arial"/><w:b/><w:bCs/><w:color w:val="1A5276"/><w:sz w:val="30"/><w:szCs w:val="30"/></w:rPr><w:t xml:space="preserve">4. El marco regulatorio aprieta: lo que ya no es opcional</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="200" w:before="0"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Arial" w:cs="Arial" w:eastAsia="Arial" w:hAnsi="Arial"/><w:sz w:val="24"/><w:szCs w:val="24"/></w:rPr><w:t xml:space="preserve">En marzo de 2026 entró en vigor la directiva europea contra el greenwashing, que exige a las empresas proporcionar información ambiental clara y verificable. No cumplir tiene consecuencias financieras y reputacionales directas. Paralelamente, el CBAM (Mecanismo de Ajuste en Frontera por Carbono) convierte las emisiones en costos de importación: las empresas que importen más de 50 toneladas anuales de materiales como acero o aluminio deben acreditar cumplimiento.</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="200" w:before="0"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Arial" w:cs="Arial" w:eastAsia="Arial" w:hAnsi="Arial"/><w:sz w:val="24"/><w:szCs w:val="24"/></w:rPr><w:t xml:space="preserve">La normativa CSRD, aunque simplificada, exige datos sólidos y útiles para la gestión — no solo check-lists de cumplimiento. El foco regulatorio se desplaza hacia la acción real y medible.</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Arial" w:cs="Arial" w:eastAsia="Arial" w:hAnsi="Arial"/><w:b/><w:bCs/><w:color w:val="1A5276"/><w:sz w:val="30"/><w:szCs w:val="30"/></w:rPr><w:t xml:space="preserve">5. Tres acciones concretas para líderes en 2026</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListParagraph"/><w:numPr><w:ilvl w:val="0"/><w:numId w:val="2"/></w:numPr><w:spacing w:after="120" w:before="120"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Arial" w:cs="Arial" w:eastAsia="Arial" w:hAnsi="Arial"/><w:b/><w:bCs/><w:color w:val="1A5276"/><w:sz w:val="24"/><w:szCs w:val="24"/></w:rPr><w:t xml:space="preserve">Auditar la infraestructura digital hoy: </w:t></w:r><w:r><w:rPr><w:rFonts w:ascii="Arial" w:cs="Arial" w:eastAsia="Arial" w:hAnsi="Arial"/><w:color w:val="222222"/><w:sz w:val="24"/><w:szCs w:val="24"/></w:rPr><w:t xml:space="preserve">Identificar qué porcentaje de operaciones corre en servidores propios vs. cloud certificado. Migrar cargas no críticas a proveedores con compromisos de energía renovable es la palanca más rápida y medible.</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListParagraph"/><w:numPr><w:ilvl w:val="0"/><w:numId w:val="2"/></w:numPr><w:spacing w:after="120" w:before="120"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Arial" w:cs="Arial" w:eastAsia="Arial" w:hAnsi="Arial"/><w:b/><w:bCs/><w:color w:val="1A5276"/><w:sz w:val="24"/><w:szCs w:val="24"/></w:rPr><w:t xml:space="preserve">Integrar métricas ESG en el tablero de control: </w:t></w:r><w:r><w:rPr><w:rFonts w:ascii="Arial" w:cs="Arial" w:eastAsia="Arial" w:hAnsi="Arial"/><w:color w:val="222222"/><w:sz w:val="24"/><w:szCs w:val="24"/></w:rPr><w:t xml:space="preserve">La sostenibilidad que no se mide no se gestiona. Incorporar KPIs de huella de carbono, consumo energético y eficiencia digital al mismo tablero donde se reportan ingresos y margen operativo.</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="ListParagraph"/><w:numPr><w:ilvl w:val="0"/><w:numId w:val="2"/></w:numPr><w:spacing w:after="120" w:before="120"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Arial" w:cs="Arial" w:eastAsia="Arial" w:hAnsi="Arial"/><w:b/><w:bCs/><w:color w:val="1A5276"/><w:sz w:val="24"/><w:szCs w:val="24"/></w:rPr><w:t xml:space="preserve">Exigir transparencia en la cadena de suministro: </w:t></w:r><w:r><w:rPr><w:rFonts w:ascii="Arial" w:cs="Arial" w:eastAsia="Arial" w:hAnsi="Arial"/><w:color w:val="222222"/><w:sz w:val="24"/><w:szCs w:val="24"/></w:rPr><w:t xml:space="preserve">Solicitar a proveedores clave información sobre su impacto ambiental no es solo cumplimiento normativo — es protección de negocio. El 56% de las pymes se mueve hacia la sostenibilidad impulsado por exigencias de grandes clientes.</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="0" w:before="200"/></w:pPr><w:r><w:t xml:space="preserve"></w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Arial" w:cs="Arial" w:eastAsia="Arial" w:hAnsi="Arial"/><w:b/><w:bCs/><w:color w:val="1A5276"/><w:sz w:val="30"/><w:szCs w:val="30"/></w:rPr><w:t xml:space="preserve">Conclusión: la sostenibilidad ya es estrategia, no reputación</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="200" w:before="0"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Arial" w:cs="Arial" w:eastAsia="Arial" w:hAnsi="Arial"/><w:sz w:val="24"/><w:szCs w:val="24"/></w:rPr><w:t xml:space="preserve">Las organizaciones que hoy lideran la sostenibilidad digital no lo hacen por imagen — lo hacen porque ven el retorno. Google lleva siete años igualando su consumo eléctrico con energía 100% renovable. Amazon es el mayor comprador corporativo de energía renovable del mundo. Estos no son gestos de marketing: son ventajas competitivas estructurales.</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="320" w:before="0"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Arial" w:cs="Arial" w:eastAsia="Arial" w:hAnsi="Arial"/><w:sz w:val="24"/><w:szCs w:val="24"/></w:rPr><w:t xml:space="preserve">En 2026, la sostenibilidad digital es la conversión de compromisos en resultados medibles que atraen capital, diferencian en el mercado y consolidan la confianza de clientes, inversores y reguladores. Los líderes que actúen ahora estarán mejor posicionados. Los que esperen, pagarán el costo de ponerse al día.</w:t></w:r></w:p><w:p><w:pPr><w:pBdr><w:top w:val="single" w:color="CCCCCC" w:sz="4" w:space="1"/></w:pBdr><w:spacing w:after="80" w:before="200"/></w:pPr></w:p><w:p><w:pPr><w:spacing w:after="0" w:before="0"/></w:pPr><w:r><w:rPr><w:rFonts w:ascii="Arial" w:cs="Arial" w:eastAsia="Arial" w:hAnsi="Arial"/><w:i/><w:iCs/><w:color w:val="888888"/><w:sz w:val="18"/><w:szCs w:val="18"/></w:rPr><w:t xml:space="preserve">Fuentes: Pacto Mundial ONU – Tendencias en sostenibilidad empresarial 2026 · KPMG Top Sustainability Themes 2026 · Gartner IT Symposium 2026 · McKinsey &amp; Company · IBM Institute for Business Value · La Página Verde Digital · Alto Perfil Magazine · Moeve Global</w:t></w:r></w:p><w:sectPr><w:pgSz w:w="12240" w:h="15840" w:orient="portrait"/><w:pgMar w:top="1440" w:right="1440" w:bottom="1440" w:left="1440" w:header="708" w:footer="708" w:gutter="0"/><w:pgNumType/><w:docGrid w:linePitch="360"/></w:sectPr></w:body></w:document>